{
  "version": 4.1,

  "meta": {
    "rules": {
      "no_hard_required": true,
      "importance_over_required": true,
      "structured_dependencies": true,
      "free_text_allowed": true,
      "validation_driven": true
    },

    "validation_defaults": {
      "severity": "error",
      "skip_if_hidden": true
    },

    "ui_behavior": {
      "show_inline_errors": true,
      "show_summary": false
    },

    "empty_values": [null, "", []],

    "updated_at": "2026-04-18T10:00:00Z"
  },

  "fever": {
    "version": 1,
    "display": { "hide_if_empty": true },

    "fields": [
      {
        "id": "fever_since_days",
        "key": "since_days",
        "label": "Duration",
        "type": "number",
        "keyboard": "numeric",
        "suffix": "days",
        "step": 1,
        "importance": "high",
        "placeholder": "e.g. 3",

        "required": false,
        "min": 0,
        "max": 365,

        "validation": {
          "type": "number",
          "required": "soft",
          "severity": "warning",
          "min": 0,
          "max": 365,
          "error_code": "FEVER_DURATION_INVALID"
        }
      },

      {
        "id": "fever_grade",
        "key": "grade",
        "label": "Grade",
        "type": "select",
        "options": ["Low Grade", "Moderate Grade", "High Grade"],

        "required": false,
        "validation": { "required": false }
      },

      {
        "id": "fever_pattern",
        "key": "pattern",
        "label": "Pattern",
        "type": "select",
        "options": ["Continuous", "Intermittent"],

        "required": false,
        "validation": { "required": false }
      },

      {
        "id": "fever_associated",
        "key": "associated_symptoms",
        "label": "Associated With",
        "type": "select",
        "options": ["Chills", "Rigors", "Sweating", "Body Ache"],
        "is_multi": true,

        "required": false,
        "validation": {
          "required": false,
          "min_items": 0,
          "max_items": 5
        }
      },

      {
        "id": "fever_additional_notes",
        "key": "additional_notes",
        "label": "Additional notes",
        "type": "textarea",

        "required": false,
        "validation": {
          "type": "text",
          "required": false,
          "max_length": 500
        }
      }
    ],

    "rules": [
      {
        "type": "warning",
        "condition": {
          "logic": "AND",
          "conditions": [
            {
              "field": "since_days",
              "operator": "greater_than",
              "value": 5
            }
          ]
        },
        "message": "Fever more than 5 days — consider further evaluation"
      }
    ]
  },

  "cough": {
    "version": 1,
    "display": { "hide_if_empty": true },

    "fields": [
      {
        "id": "cough_type",
        "key": "type",
        "label": "Type",
        "type": "select",
        "options": ["Dry", "Productive (Wet)", "Barking"],

        "default": {
          "value": "Dry",
          "apply_on": ["init"]
        },

        "required": false,
        "validation": { "required": "soft" }
      },

      {
        "id": "cough_sputum",
        "key": "sputum_color",
        "label": "Sputum Color",
        "type": "select",
        "options": ["Clear", "Yellow/Green", "Blood Stained"],

        "required": false,

        "visibility": {
          "depends_on": {
            "field": "type",
            "operator": "equals",
            "value": "Productive (Wet)"
          },
          "clear_on_hide": true
        },

        "validation": {
          "required": "soft",
          "severity": "warning",
          "depends_on": {
            "field": "type",
            "operator": "equals",
            "value": "Productive (Wet)"
          },
          "skip_if_hidden": true
        }
      },

      {
        "id": "cough_worse_at",
        "key": "worse_at",
        "label": "Worse At",
        "type": "select",
        "options": ["Night", "Early Morning", "On Exertion"],
        "is_multi": true,

        "required": false,
        "validation": {
          "required": false,
          "min_items": 0,
          "max_items": 3
        }
      },

      {
        "id": "cough_additional_notes",
        "key": "additional_notes",
        "label": "Additional notes",
        "type": "textarea",

        "required": false,
        "validation": {
          "type": "text",
          "required": false,
          "max_length": 500
        }
      }
    ]
  },

  "headache": {
    "version": 1,
    "display": { "hide_if_empty": true },

    "fields": [
      {
        "id": "headache_location",
        "key": "location",
        "label": "Location",
        "type": "select",
        "options": [
          "Frontal",
          "One-sided (Migraine)",
          "Back of Head",
          "Generalized"
        ],
        "importance": "high",

        "required": false,
        "validation": { "required": "soft" }
      },

      {
        "id": "headache_pain_score",
        "key": "pain_score",
        "label": "Pain Score (1–10)",
        "type": "number",

        "required": false,
        "min": 1,
        "max": 10,

        "validation": {
          "type": "number",
          "required": "soft",
          "severity": "warning",
          "min": 1,
          "max": 10,
          "error_code": "HEADACHE_SCORE_INVALID"
        }
      },

      {
        "id": "headache_additional_notes",
        "key": "additional_notes",
        "label": "Additional notes",
        "type": "textarea",

        "required": false,
        "validation": {
          "type": "text",
          "required": false,
          "max_length": 500
        }
      }
    ]
  }
}